@{
    ViewData["Title"] = "Inicio";
}

<div class="p-5 mb-4 bg-primary text-white rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">
            <i class="bi bi-shop me-3"></i>Bienvenido a TiendaMVC
        </h1>
        <p class="col-md-8 fs-5">Sistema de gestión de productos con operaciones CRUD completas.</p>
        <p>TEAM 2 <br />
          1 - Miguel Joel Brito</p>
        <a class="btn btn-light btn-lg fw-bold" asp-controller="Productos" asp-action="Index">
            <i class="bi bi-box-seam me-2"></i>Ver Productos
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-3">
        <a asp-controller="Productos" asp-action="Create" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 card-hover">
                <i class="bi bi-plus-circle fs-1 text-success mb-2"></i>
                <h5 class="text-dark">Crear</h5>
                <p class="text-muted small">Agrega nuevos productos al sistema</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Productos" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 card-hover">
                <i class="bi bi-list-ul fs-1 text-primary mb-2"></i>
                <h5 class="text-dark">Consultar</h5>
                <p class="text-muted small">Lista todos los productos registrados</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Productos" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 card-hover">
                <i class="bi bi-pencil-square fs-1 text-warning mb-2"></i>
                <h5 class="text-dark">Editar</h5>
                <p class="text-muted small">Modifica la información de productos</p>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a asp-controller="Productos" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 card-hover">
                <i class="bi bi-trash fs-1 text-danger mb-2"></i>
                <h5 class="text-dark">Eliminar</h5>
                <p class="text-muted small">Elimina productos del sistema</p>
            </div>
        </a>
    </div>
</div>
